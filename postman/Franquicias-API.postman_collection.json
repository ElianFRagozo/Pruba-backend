        {
          "name": "05 - Agregar producto",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "if (body.branches && body.branches.length > 0) {",
                  "    var b = body.branches.find(function(x){ return x.id === pm.collectionVariables.get('branchId'); }) || body.branches[0];",
                  "    if (b && b.products && b.products.length > 0) {",
                  "        pm.collectionVariables.set('productId', b.products[b.products.length - 1].id);",
                  "    }",
                  "}"
                ]
              }
            }
